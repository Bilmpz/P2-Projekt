<div class="container">

  <section class="card hero-card" style="display: flex; justify-content: space-between; align-items: flex-start; gap: 24px; flex-wrap: wrap;">
    <div>
      <h1><%= group.name %></h1>
      <div class="feed-meta" style="margin-top:12px;">
        <% if (group.department) { %>
          <span><%= group.department %></span>
        <% } %>
        <% if (group.location) { %>
          <span>•</span>
          <span><%= group.location %></span>
        <% } %>
      </div>
    </div>
    <div class="card-actions" style="display: flex; gap: 12px; align-items: center; flex-shrink: 0;">
      <% if (isMember) { %>
        <form action="/main/groups/<%= group._id %>/leave" method="POST" style="display:inline;"
              onsubmit="return confirm('Forlad <%= group.name %>?');">
          <button type="submit" class="join-btn is-joined">✓ Joined</button>
        </form>
      <% } else { %>
        <form action="/main/groups/<%= group._id %>/join" method="POST" style="display:inline;">
          <button type="submit" class="join-btn">Tilmeld</button>
        </form>
      <% } %>
      <a class="primary-btn" href="/main/post/create?group=<%= group._id %>">＋ Nyt opslag</a>
    </div>
  </section>

  <section class="page-head">
    <h2 class="section-title">Study Buddy Requests</h2>
    <p>
      <% if (posts.length === 0) { %>
        Ingen opslag endnu — vær den første!
      <% } else { %>
        <%= posts.length %> studerende søger læsemakkere i dette fag.
      <% } %>
    </p>
  </section>

  <section class="feed-stack">
    <% posts.forEach(post => { %>
      <%
        const isOwn = currentUserId && post.user && post.user._id.toString() === currentUserId;
        const ageMs = Date.now() - new Date(post.createdAt).getTime();
        const ageDays = Math.floor(ageMs / (1000 * 60 * 60 * 24));
        const isNew = ageDays < 2;
        let timeLabel;
        if (ageDays === 0) timeLabel = "I dag";
        else if (ageDays === 1) timeLabel = "1 dag siden";
        else timeLabel = ageDays + " dage siden";
      %>
      <article class="feed-card <%= isNew ? 'is-new' : '' %>">
        <div class="feed-header">
          <span class="kicker">Opslag</span>
          <% if (isOwn) { %>
            <div class="badge gray">Dit opslag</div>
          <% } else if (isNew) { %>
            <div class="badge primary">Ny</div>
          <% } %>
        </div>

        <h3 class="feed-title"><%= post.title %></h3>

        <dl class="feed-details">
          <div class="feed-row">
            <dt>Navn</dt>
            <dd><%= post.user ? post.user.username : "Ukendt" %></dd>
          </div>

          <div class="feed-row">
            <dt>Besked</dt>
            <dd><%= post.content %></dd>
          </div>

          <% if (post.availability) { %>
            <div class="feed-row">
              <dt>Tilgængelig</dt>
              <dd><%= post.availability %></dd>
            </div>
          <% } %>

          <div class="feed-row">
            <dt>Oprettet</dt>
            <dd><%= timeLabel %></dd>
          </div>
        </dl>

        <div class="feed-footer">
          <a class="text-link" href="/main/post/<%= post._id %>">Åbn opslag</a>
          <% if (!isOwn && post.user && post.user.email) { %>
            <a
              class="message-btn"
              href="mailto:<%= post.user.email %>?subject=Ang%C3%A5ende%20dit%20opslag:%20<%= encodeURIComponent(post.title) %>&body=Hej%20<%= encodeURIComponent(post.user.username) %>,%0A%0AJeg%20er%20interesseret%20i%20dit%20opslag.%0A%0AVh"
            >
              Send email
            </a>
<% } %>
        </div>
      </article>
    <% }) %>
  </section>

</div>