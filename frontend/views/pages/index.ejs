<!DOCTYPE html>
<html lang="da">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AAU Study Buddy – Loginside</title>
  <link rel="stylesheet" href="css/styles.css">
</head>
<body>
  <main class="login-page">
    <section class="login-shell">
      <div class="login-brand-panel">
        <div class="brand">
          <span>
            Study Buddy
            <small>AAU</small>
          </span> 
        </div>

        <div>
          <h1>Velkommen tilbage</h1>
          <p>Log ind og få adgang til dit feed, dine grupper og booking af grupperum.</p>
        </div>

        <ul class="login-points">
          <li><span>✓</span><span>Se opslag fra dine fag og studiegrupper</span></li>
          <li><span>✓</span><span>Find study buddies til kurser og projekter</span></li>
        </ul>

        <div class="login-mini-card">
          <h2>Studieliv samlet ét sted</h2>
        </div>
      </div>

      <div class="login-form-panel">
        <div class="page-head" style="margin-bottom: 0;">
          <h2>Log ind</h2>
          <p>Brug din AAU-mail for at fortsætte.</p>
        </div>

        <form class="stack">
          <div class="field" id="usernameField">
            <label for="username">Brugernavn</label>
            <input id="usernameInput" type="text" placeholder="Dit brugernavn">
          </div>

          <div class="field">
            <label for="email">AAU e-mail</label>
            <input id="emailInput" type="email" placeholder="navn@student.aau.dk">
          </div>

          <div class="field">
            <label for="password">Adgangskode</label>
            <input id="passwordInput" type="password" placeholder="Skriv din adgangskode">
          </div>

          <div class="login-actions">
            <label class="checkbox-row" for="remember-me">
              <input id="remember-me" type="checkbox">
              <span>Husk mig</span>
            </label>
            <a class="muted-link" href="#">Glemt kodeord?</a>
          </div>

          <p id="error" style="display:none; color:rgb(245, 134, 134);"></p>

        <button id="authBtn" type="button" class="primary-btn" onclick="login()">Log ind</button>
        <button id="registerBtn" type="button" class="secondary-btn" onclick="register()">Opret bruger</button>
        </form>
    </section>
  </main>

  <script src="js/index.js"></script>


</body>
</html>
