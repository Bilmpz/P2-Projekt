<!DOCTYPE html>
<html lang="da">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AAU Study Buddy – Loginside</title>
  <link rel="stylesheet" href="css/styles.css">
</head>
<body>
  <main class="login-page">
    <section class="login-shell">
      <div class="login-brand-panel">
        <div class="brand">
          <span>
            Study Buddy
            <small>AAU</small>
          </span> 
        </div>

        <div>
          <h1>Velkommen tilbage</h1>
          <p>Log ind og få adgang til dit feed, dine grupper og booking af grupperum.</p>
        </div>

        <ul class="login-points">
          <li><span>✓</span><span>Se opslag fra dine fag og studiegrupper</span></li>
          <li><span>✓</span><span>Find study buddies til kurser og projekter</span></li>
        </ul>

        <div class="login-mini-card">
          <h2>Studieliv samlet ét sted</h2>
        </div>
      </div>

      <div class="login-form-panel">
        <div class="page-head" style="margin-bottom: 0;">
          <h2>Log ind</h2>
          <p>Brug din AAU-mail for at fortsætte.</p>
        </div>
      <!-- Når bruger er blevet oprettet-->
      <% if (registered) { %>
        <div class="success-message">
          Bruger oprettet! Du kan nu logge ind.
        </div>
      <% } %>
      <!-- Error hvis bruger ikke fundet -->
      <% if (error === "invalid-login") { %>
        <div class="error-message">
          Forkert email eller password
        </div>
      <% } %>

    <% if (error === "email-exists") { %>
      <div class="error-message">
        Email findes allerede
      </div>
    <% } %>

  <!-- TOGGLE BUTTONS -->
  <div class="auth-switch">
    <button id="showLogin" class="switch-btn active">
      Login
    </button>

    <button id="showRegister" class="switch-btn">
      Register
    </button>
  </div>

  <!-- LOGIN FORM -->
  <form id="loginForm" action="/auth/login" method="POST" class="auth-form">
    <div class="field">
      <label>Email</label>
      <input type="email" name="email" required>
    </div>

    <div class="field">
      <label>Password</label>
      <input type="password" name="password" required>
    </div>

    <button type="submit" class="primary-btn">
      Login
    </button>
  </form>

  <!-- REGISTER FORM -->
  <form id="registerForm" action="/auth/register" method="POST" class="auth-form hidden">
    <div class="field">
      <label>Username</label>
      <input class ="registerInput"  type="text" name="username" minlength="3" maxlength="30" required>
    </div>

    <div class="field">
      <label>Email</label>
      <input class ="registerInput" type="email" name="email" required>
    </div>

    <div class="field">
      <label>Password</label>
      <input class ="registerInput" type="password" name="password" required minlength="6" maxlength="128">
    </div>

    <button type="submit" class="primary-btn">
      Opret bruger
    </button>
  </form>

</div>
    </section>
  </main>

  <script src="js/index.js"></script>


</body>
</html>
